{
  "name": "worldcup-tiktok-bot",
  "version": "1.0.0",
  "description": "Daily auto-generated World Cup 2026 fact videos for TikTok",
  "type": "module",
  "scripts": {
    "fetch": "node scripts/fetch-data.mjs",
    "preview": "remotion studio",
    "render": "remotion render MatchFacts out/today.mp4",
    "post": "node scripts/post-tiktok.mjs out/today.mp4",
    "daily": "npm run fetch && npm run render && npm run post"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
